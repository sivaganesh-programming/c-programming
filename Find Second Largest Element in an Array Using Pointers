#include <stdio.h>

int main() {
    int arr[] = {10, 25, 7, 30, 15};
    int n = 5;
    int *p = arr;
    int first = *p, second = *p;

    for(int i=1; i<n; i++) {
        if(*(p+i) > first) {
            second = first;
            first = *(p+i);
        } else if(*(p+i) > second && *(p+i) != first) {
            second = *(p+i);
        }
    }

    printf("Second Largest = %d", second);
    return 0;
}
