#include <stdio.h>
#include <stdlib.h>

int main() {
    int n = 4;
    int *arr;
    int sum = 0;

    arr = (int *)malloc(n * sizeof(int));

    arr[0] = 10;
    arr[1] = 20;
    arr[2] = 30;
    arr[3] = 40;

    for(int i = 0; i < n; i++) {
        sum += arr[i];
    }

    printf("Sum = %d\n", sum);
    printf("Average = %.2f", (float)sum/n);

    free(arr);
    return 0;
}
