#include <stdio.h>

int main() {
    char str[]="program";
    int i,j;

    for(i=0;str[i];i++){
        for(j=i+1;str[j];j++){
            if(str[i]==str[j]){
                for(int k=j;str[k];k++)
                    str[k]=str[k+1];
                j--;
            }
        }
    }

    printf("After Remove = %s",str);
    return 0;
}
