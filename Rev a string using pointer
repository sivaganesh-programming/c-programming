#include <stdio.h>
#include <string.h>
int main(){
    char str[]="Hello";
    char *start=str, *end=str+strlen(str)-1;
    char temp;
    while(start<end){
        temp=*start;
        *start=*end;
        *end=temp;
        start++;
        end--;
    }
    printf("Reversed=%s", str);
    return 0;
}
